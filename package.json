{
  "name": "claude-kanban",
  "version": "0.1.0",
  "description": "Claude Code multi-task kanban management panel",
  "bin": {
    "ck": "./dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"tsx watch src/cli.ts --dev --no-open\" \"cd client && vite --port 14568\"",
    "dev:electron": "concurrently \"tsx src/cli.ts --dev --no-open\" \"cd client && vite --port 14568\" \"env -u ELECTRON_RUN_AS_NODE electron dist/electron/main.js\"",
    "build": "tsc && cd client && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:all": "npm run build && npm run build:electron",
    "start": "node dist/cli.js",
    "start:electron": "env -u ELECTRON_RUN_AS_NODE electron dist/electron/main.js",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "prepack": "npm run build"
  },
  "main": "dist/electron/main.js",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "uuid": "^9.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo"
  ],
  "private": false,
  "build": {
    "appId": "com.claude-kanban.app",
    "productName": "Claude Kanban",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
